# Environment Configuration Template for Carbifyio
# Copy this file to '.env' inside the 'backend' directory (backend/.env) and configure the variables.

# Environment mode: development, production, testing
ENV=development

# JWT Secret Key - MUST be a secure, random 32-byte hex string in production.
# To generate a new one, run: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secure_jwt_secret_key_here

# SQLite Database connection URL
DATABASE_URL=sqlite:////app/data/carbify.db
